PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=sua_chave_secreta_aqui_troque_em_producao
JWT_EXPIRES_IN=7d

# Database (SQLite por padrão, fácil de trocar para PostgreSQL/MySQL)
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# Para PostgreSQL (descomente se precisar)
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=presensee
# DB_USER=postgres
# DB_PASSWORD=senha

# Regras de negócio
MAX_ABSENCE_PERCENT=25
MAX_CONSECUTIVE_ABSENCES=4
